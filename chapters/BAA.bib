\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1002/9783433611029.ch16},
	keywords = {Bauen 4.0, digitale Transformation, digitaler Zwilling, interdisziplinäres vernetztes Arbeiten},
	pages = {499--519},
	file = {Full Text PDF:/Users/lukasstoeckli/Zotero/storage/5WJ4EQAL/Obergrießer and Kraus - 2022 - Digitale Transformation im Bauwesen – von der Theo.pdf:application/pdf;Snapshot:/Users/lukasstoeckli/Zotero/storage/G5CW5HLA/9783433611029.html:text/html},
